[global_config]
  focus = system
  geometry_hinting = True
[keybindings]
[profiles]
  [[default]]
    background_color    = "#0d0d0d"
    background_darkness = 0.92
    background_type     = transparent
    font                = SpaceMono Nerd Font Mono 11
    foreground_color    = "#c8c8c8"
    show_titlebar       = False
    scrollbar_position  = hidden
    use_system_font     = False
    copy_on_selection   = True
    cursor_color        = "#ffffff"
    # Monochrome palette — shades of gray with white as bright
    palette = "#0d0d0d:#888888:#aaaaaa:#cccccc:#ffffff:#bbbbbb:#999999:#c8c8c8:#222222:#aaaaaa:#bbbbbb:#dddddd:#ffffff:#cccccc:#b0b0b0:#e8e8e8"
[layouts]
  [[default]]
    [[[child1]]]
      parent = window0
      type   = Terminal
    [[[window0]]]
      parent = ""
      type   = Window
[plugins]
